{
  "type": "module",
  "name": "niner-api",
  "version": "1.0.0",
  "description": "",
  "module": "server.ts",
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "start": "bun ./out/server.js",
    "dev": "bun --watch server.ts",
    "build": "bun build --target=bun ./server.ts --outdir ./out",
    "lint": "eslint --ext .ts,.js src/",
    "format": "prettier --write --ignore-path=.gitignore .",
    "format:check": "prettier --check --ignore-path=.gitignore .",
    "prepare": "husky install"
  },
  "devDependencies": {
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/morgan": "^1.9.9",
    "@typescript-eslint/parser": "^6.11.0",
    "bun-types": "latest",
    "eslint": "^8.54.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-prettier": "^5.0.1",
    "husky": "^8.0.3",
    "morgan": "^1.10.0",
    "prettier": "^3.1.0"
  },
  "peerDependencies": {
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "helmet": "^7.1.0",
    "http-status-codes": "^2.3.0",
    "lodash": "^4.17.21",
    "winston": "^3.11.0",
    "zod": "^3.22.4"
  }
}
